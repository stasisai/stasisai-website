---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ObservatoryTimeline from '../components/ObservatoryTimeline.jsx';
---

<Layout title="MAFIS Simulator | Calibrating">
  <Header />

  <div class="sim-container">
    <div class="sim-content">

      <!-- Status Badge -->
      <div class="status-badge">
        <span class="status-dot"></span>
        STATUS: COMPILING // WASM32-UNKNOWN-UNKNOWN
      </div>

      <!-- Title -->
      <h1 class="sim-title">
        The observatory is being <em>calibrated.</em>
      </h1>

      <!-- Description -->
      <p class="sim-desc">
        The full simulation engine is written in Rust using the Bevy framework, compiled to WebAssembly. No server, no install — open a URL and run fault injection experiments at 60fps directly in the browser.
      </p>

      <!-- Observatory Timeline Preview -->
      <div class="sim-timeline">
        <span class="timeline-label">PREVIEW: THROUGHPUT CURVE</span>
        <ObservatoryTimeline client:only="react" />
      </div>

      <!-- Build Pipeline -->
      <div class="pipeline-card">
        <span class="pipeline-title">BUILD PIPELINE</span>
        <ul class="pipeline-list">
          <li class="pipeline-item done">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#047857" stroke-width="1.5"/><path d="M4 7l2 2 4-4" stroke="#047857" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Core ECS architecture
          </li>
          <li class="pipeline-item done">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#047857" stroke-width="1.5"/><path d="M4 7l2 2 4-4" stroke="#047857" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            PIBT solver (lifelong mode)
          </li>
          <li class="pipeline-item done">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#047857" stroke-width="1.5"/><path d="M4 7l2 2 4-4" stroke="#047857" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Fault injection systems
          </li>
          <li class="pipeline-item active">
            <span class="spinner"></span>
            WASM bindings + JS bridge
          </li>
          <li class="pipeline-item pending">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/></svg>
            Browser integration
          </li>
        </ul>
      </div>

      <!-- Links -->
      <div class="sim-links">
        <a href="/docs/developers/getting-started/architecture" class="btn-sim">Read the Architecture Docs</a>
        <a href="/" class="btn-sim btn-sim-ghost">Return Home</a>
      </div>

    </div>
  </div>

  <style>
    .sim-container {
      min-height: 100vh;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg);
      color: var(--text);
      padding: 120px 24px 80px;
    }
    .sim-content {
      max-width: 700px;
      width: 100%;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
    }

    /* Status badge */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text-sec);
      padding: 8px 18px;
      border: 1px solid var(--border);
    }
    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 0.4; box-shadow: 0 0 0 0 rgba(4,120,87,0.4); }
      50% { opacity: 1; box-shadow: 0 0 8px 2px rgba(4,120,87,0.3); }
    }

    /* Title */
    .sim-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 1.1;
      letter-spacing: -1px;
      color: var(--text);
      margin: 0;
    }
    .sim-title em {
      color: var(--text);
      opacity: 0.35;
      font-style: italic;
    }

    /* Description */
    .sim-desc {
      font-family: var(--sans);
      font-weight: 300;
      font-size: 1rem;
      color: var(--text-sec);
      max-width: 520px;
      line-height: 1.7;
      margin: 0;
    }

    /* Timeline */
    .sim-timeline {
      width: 100%;
      max-width: 800px;
    }
    .timeline-label {
      display: block;
      font-family: var(--mono);
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text-sec);
      opacity: 0.6;
      margin-bottom: 12px;
    }

    /* Pipeline */
    .pipeline-card {
      width: 100%;
      max-width: 420px;
      border: 1px solid var(--border);
      padding: 24px 28px;
      text-align: left;
    }
    .pipeline-title {
      display: block;
      font-family: var(--mono);
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text-sec);
      opacity: 0.7;
      margin-bottom: 16px;
    }
    .pipeline-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .pipeline-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.03em;
    }
    .pipeline-item.done { color: var(--text-sec); }
    .pipeline-item.active { color: var(--text); }
    .pipeline-item.pending { color: var(--text-sec); opacity: 0.35; }

    .spinner {
      width: 14px;
      height: 14px;
      border: 1.5px solid var(--border);
      border-top-color: var(--green);
      border-radius: 50%;
      flex-shrink: 0;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Links */
    .sim-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 8px;
    }
    .btn-sim {
      display: inline-block;
      font-family: var(--mono);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 12px 28px;
      text-decoration: none;
      transition: opacity 0.2s;
      border-radius: 0;
      background: var(--dark);
      color: var(--bg);
    }
    .btn-sim:hover { opacity: 0.8; }
    .btn-sim-ghost {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
    }
    .btn-sim-ghost:hover { opacity: 0.7; }
  </style>
</Layout>
