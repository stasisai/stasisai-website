---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import KineticGrid from '../components/KineticGrid.jsx';
import ThesisScene from '../components/ThesisScene.jsx';
import ObservatoryTimeline from '../components/ObservatoryTimeline.jsx';
import CascadeScene from '../components/CascadeScene.jsx';
---

<Layout title="MAFIS by Stasis | Fault Resilience Observatory">

  <Header />

  <!-- SNAP SCROLL CONTAINER -->
  <div class="snap-container">

    <!-- ══════════ SECTION 1: HERO ══════════ -->
    <section class="hero-section">
      <div class="hero-canvas-wrapper">
        <KineticGrid client:only="react" />
      </div>

      <!-- Readability gradient -->
      <div class="hero-gradient"></div>

      <!-- Hero content -->
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-title">
            Resilience is not<br/>
            <em>performance.</em>
          </h1>
          <p class="hero-subtitle">
            MAFIS (Multi-Agent Fault Injection Simulator) is a fault resilience
            observatory for lifelong multi-agent systems.
          </p>
          <div class="hero-cta">
            <a href="#the-gap" class="btn-primary">Explore the research ↓</a>
            <a href="/simulator" class="btn-docs">Try Simulator</a>
          </div>
        </div>
      </div>

      <div class="scroll-hint">
        <p>scroll</p>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ══════════ SECTION 2: THE GAP ══════════ -->
    <section class="gap-section" id="the-gap">
      <div class="gap-inner fade-in-up">
        <span class="section-label">THE GAP</span>
        <h2 class="gap-title">Every MAPF benchmark assumes a <em>perfect world.</em></h2>
        <p class="gap-text">
          Existing tools compare solver speed on static grids with no failures,
          no congestion, and no sustained operation. But no warehouse runs
          without faults. No fleet operates in ideal conditions. Few benchmarks
          ask the question:
        </p>
        <blockquote class="gap-quote">
          "What happens to your fleet when things go wrong,
           and keep going wrong?"
        </blockquote>
      </div>
    </section>

    <!-- ══════════ SECTION 3: THE THESIS ══════════ -->
    <section class="thesis-section">
      <div class="section-inner">
        <div class="thesis-text fade-in-up">
          <span class="section-label">THE HYPOTHESIS</span>
          <h2 class="thesis-title">Performance does not predict <em>resilience.</em></h2>
          <p class="thesis-desc">
            The same solver. The same map. The same fault.
            One system recovers. The other collapses.
            The only difference is how tasks were assigned.
          </p>
        </div>

        <div class="thesis-scenes" id="thesis-scenes">
          <ThesisScene client:only="react" />
        </div>

        <p class="thesis-caption">
          Same solver. Same map. Same fault.
          Different scheduler → different resilience profile.
        </p>
      </div>
    </section>

    <!-- ══════════ SECTION 4: THE OBSERVATORY ══════════ -->
    <section class="observatory-section">
      <div class="section-inner">
        <div class="observatory-text fade-in-up">
          <span class="section-label">THE OBSERVATORY</span>
          <h2 class="observatory-title">Two phases. Four metrics. One resilience <em>profile.</em></h2>
          <p class="observatory-desc">
            Every MAFIS run computes a fault-free baseline instantly,
            then runs the live simulation with faults active from tick one.
            The delta between clean and degraded performance is the research output.
          </p>
        </div>

        <div class="observatory-timeline" id="observatory-timeline">
          <ObservatoryTimeline client:only="react" />
        </div>

        <div class="scorecard" id="resilience-scorecard">
          <h4 class="scorecard-title">RESILIENCE SCORECARD</h4>
          <div class="scorecard-metric">
            <span class="scorecard-metric-label">Fault Tolerance</span>
            <span class="scorecard-metric-value sc-green"><span class="counter" data-target="82" data-start="0" data-format="decimal">0</span></span>
          </div>
          <div class="scorecard-metric">
            <span class="scorecard-metric-label">NRR</span>
            <span class="scorecard-metric-value sc-blue"><span class="counter" data-target="91" data-start="0" data-format="decimal">0</span></span>
          </div>
          <div class="scorecard-metric">
            <span class="scorecard-metric-label">Fleet Utilization</span>
            <span class="scorecard-metric-value sc-orange"><span class="counter" data-target="64" data-start="0" data-format="decimal">0</span></span>
          </div>
          <div class="scorecard-metric">
            <span class="scorecard-metric-label">Critical Time</span>
            <span class="scorecard-metric-value sc-muted"><span class="counter" data-target="15" data-start="0" data-format="decimal">0</span></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════ SECTION 5: CASCADE PROPAGATION ══════════ -->
    <section class="cascade-section">
      <div class="section-inner">
        <div class="cascade-layout">
          <div class="cascade-text fade-in-up">
            <span class="section-label">CASCADE PROPAGATION</span>
            <h2 class="cascade-title">One fault. Twenty-three agents <em>affected.</em></h2>
            <p class="cascade-desc">
              When an agent dies, it becomes a permanent obstacle. Agents behind
              it replan, but their new paths block others, who block others still.
              MAFIS traces this chain reaction and measures how deep and wide
              the damage spreads.
            </p>
          </div>

          <div class="cascade-scene-wrapper">
            <div class="cascade-scene" id="cascade-scene">
              <CascadeScene client:only="react" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════ SECTION 6: THE ENGINE ══════════ -->
    <section class="dark-section">
      <div class="section-inner">
        <h2 class="dark-title">
          Built in Rust.<br/>
          <em>Powered by Bevy.</em>
        </h2>

        <!-- Pillar Group for Hover Fading -->
        <div class="pillar-group">
          <!-- Pillar 1: Entity Component System -->
          <div class="pillar-row">
            <div class="pillar-icon-box">
              <span class="pillar-mod">MOD.01</span>
              <img src="/stasis-research.svg" alt="Entity Component System" class="pillar-icon" />
            </div>
            <div class="pillar-content">
              <h3 class="pillar-title" style="color:#3DB8E8;">
                <span class="pillar-line" style="background:#3DB8E8;"></span>Entity Component System
              </h3>
              <p class="pillar-text">
                Built on <a href="https://bevyengine.org/" target="_blank" rel="noopener noreferrer" class="bevy-link"><strong>Bevy</strong></a>. Data-oriented, cache-friendly, parallelizable. Fault injection, heat propagation, and replanning compose without coupling.
              </p>
            </div>
          </div>

          <!-- Pillar 2: Blazing Fast -->
          <div class="pillar-row">
            <div class="pillar-icon-box">
              <span class="pillar-mod">MOD.02</span>
              <img src="/stasis-blazing-fast.svg" alt="Blazing Fast" class="pillar-icon" />
            </div>
            <div class="pillar-content">
              <h3 class="pillar-title" style="color:#E8862A;">
                <span class="pillar-line" style="background:#E8862A;"></span>Blazing Fast
              </h3>
              <p class="pillar-text">
                Zero-cost abstractions. No garbage collector, no runtime overhead. Memory safety at compile time. 500-agent fault simulations without a single allocation in the hot loop.
              </p>
            </div>
          </div>

          <!-- Pillar 3: WebAssembly -->
          <div class="pillar-row">
            <div class="pillar-icon-box">
              <span class="pillar-mod">MOD.03</span>
              <img src="/stasis-fault.svg" alt="WebAssembly" class="pillar-icon" />
            </div>
            <div class="pillar-content">
              <h3 class="pillar-title" style="color:#34D399;">
                <span class="pillar-line" style="background:#34D399;"></span>WebAssembly
              </h3>
              <p class="pillar-text">
                Compiles to WASM and runs in the browser. No server, no install. Open a URL and run 500-agent experiments at 60fps.
              </p>
            </div>
          </div>
        </div>

        <div class="stats-grid" id="performance-stats">
          <div class="stat">
            <span class="stat-value stat-red">[<span class="counter" data-target="450" data-start="0">0</span>]</span>
            <span class="stat-label">Concurrent Agents</span>
            <div class="stat-bar"><div class="stat-fill" data-color="var(--red)" data-width="90%" style="width: 0%; background: var(--red);"></div></div>
          </div>
          <div class="stat">
            <span class="stat-value stat-green">[<span class="counter" data-target="60" data-start="0">0</span> FPS]</span>
            <span class="stat-label">Fluid Rendering</span>
            <div class="stat-bar"><div class="stat-fill" data-color="var(--green)" data-width="100%" style="width: 0%; background: var(--green);"></div></div>
          </div>
          <div class="stat">
            <span class="stat-value">[<span class="counter" data-target="0" data-start="120">120</span>MS]</span>
            <span class="stat-label">Latency Overhead</span>
            <div class="stat-bar"><div class="stat-fill" data-color="rgba(240,237,233,0.5)" data-width="5%" style="width: 100%; background: rgba(240,237,233,0.5);"></div></div>
          </div>
        </div>

        <p class="bevy-credit fade-in-up">
          Powered by <a href="https://bevyengine.org/" target="_blank" rel="noopener noreferrer" class="bevy-credit-link">Bevy</a>, an open-source engine driven by its community of contributors.
        </p>
      </div>
    </section>

    <!-- ══════════ SECTION 7: ECOSYSTEM & COMMUNITY ══════════ -->
    <section class="community-section">
      <div class="section-inner">
        <h3 class="community-title">The MAPF <em>Ecosystem</em></h3>
        <p class="community-intro">
          MAFIS answers one question: how do multi-agent systems behave under faults? Everything else has a home.
        </p>

        <div class="ecosystem-grid">
          <div class="eco-card">
            <div class="eco-bg-number">01</div>
            <div class="eco-header">
              <div class="eco-tag">Ecosystem . 01</div>
              <div class="eco-icon-anim">
                <!-- Animated bar chart icon -->
                <svg width="28" height="20" viewBox="0 0 28 20" class="eco-anim-svg">
                  <rect class="eco-bar eco-bar-1" x="2" y="12" width="4" height="8" rx="1" fill="#047857" opacity="0.7" />
                  <rect class="eco-bar eco-bar-2" x="8" y="6" width="4" height="14" rx="1" fill="#3DB8E8" opacity="0.7" />
                  <rect class="eco-bar eco-bar-3" x="14" y="2" width="4" height="18" rx="1" fill="#047857" opacity="0.9" />
                  <rect class="eco-bar eco-bar-4" x="20" y="8" width="4" height="12" rx="1" fill="#3DB8E8" opacity="0.7" />
                </svg>
              </div>
            </div>
            <h4 class="eco-title">Algorithm Benchmarking</h4>
            <p class="eco-text">
              For solver comparisons and leaderboards, see the <strong>MAPF Tracker</strong>.
            </p>
            <a href="https://tracker.pathfinding.ai/" target="_blank" rel="noopener noreferrer" class="eco-link">Visit MAPF Tracker ↗</a>
          </div>

          <div class="eco-card">
            <div class="eco-bg-number">02</div>
            <div class="eco-header">
              <div class="eco-tag">Ecosystem . 02</div>
              <div class="eco-icon-anim">
                <!-- Animated grid/maze icon -->
                <svg width="24" height="24" viewBox="0 0 24 24" class="eco-anim-svg">
                  <rect class="eco-cell eco-cell-1" x="1" y="1" width="6" height="6" rx="1" fill="#E8862A" opacity="0.5" />
                  <rect class="eco-cell eco-cell-2" x="9" y="1" width="6" height="6" rx="1" fill="#991B1B" opacity="0.6" />
                  <rect class="eco-cell eco-cell-3" x="17" y="1" width="6" height="6" rx="1" fill="#E8862A" opacity="0.4" />
                  <rect class="eco-cell eco-cell-4" x="1" y="9" width="6" height="6" rx="1" fill="#991B1B" opacity="0.3" />
                  <rect class="eco-cell eco-cell-5" x="9" y="9" width="6" height="6" rx="1" fill="#047857" opacity="0.6" />
                  <rect class="eco-cell eco-cell-6" x="17" y="9" width="6" height="6" rx="1" fill="#991B1B" opacity="0.5" />
                  <rect class="eco-cell eco-cell-7" x="1" y="17" width="6" height="6" rx="1" fill="#E8862A" opacity="0.6" />
                  <rect class="eco-cell eco-cell-8" x="9" y="17" width="6" height="6" rx="1" fill="#E8862A" opacity="0.3" />
                  <rect class="eco-cell eco-cell-9" x="17" y="17" width="6" height="6" rx="1" fill="#047857" opacity="0.5" />
                </svg>
              </div>
            </div>
            <h4 class="eco-title">Standard Instances</h4>
            <p class="eco-text">
              For standardized 2D grid test environments and scenarios, see the <strong>MovingAI MAPF Benchmarks</strong>.
            </p>
            <a href="https://movingai.com/benchmarks/mapf.html" target="_blank" rel="noopener noreferrer" class="eco-link">View MovingAI Benchmarks ↗</a>
          </div>

          <div class="eco-card">
            <div class="eco-bg-number">03</div>
            <div class="eco-header">
              <div class="eco-tag">Ecosystem . 03</div>
              <div class="eco-icon-anim">
                <!-- Animated robot icon -->
                <svg width="24" height="24" viewBox="0 0 24 24" class="eco-anim-svg">
                  <line class="eco-arm eco-arm-1" x1="12" y1="4" x2="12" y2="1" stroke="#047857" stroke-width="1.5" stroke-linecap="round" opacity="0.7" />
                  <circle class="eco-endpoint eco-ep-1" cx="12" cy="0.5" r="1.5" fill="#047857" opacity="0.8" />
                  <rect class="eco-cell eco-cell-1" x="7" y="4" width="10" height="7" rx="2" fill="#3DB8E8" opacity="0.8" />
                  <circle cx="10" cy="7.5" r="1.2" fill="#111" />
                  <circle cx="14" cy="7.5" r="1.2" fill="#111" />
                  <rect class="eco-cell eco-cell-2" x="8" y="12" width="8" height="8" rx="1" fill="#3DB8E8" opacity="0.6" />
                  <line class="eco-arm eco-arm-2" x1="8" y1="14" x2="4" y2="17" stroke="#3DB8E8" stroke-width="2" stroke-linecap="round" opacity="0.5" />
                  <line class="eco-arm eco-arm-3" x1="16" y1="14" x2="20" y2="17" stroke="#3DB8E8" stroke-width="2" stroke-linecap="round" opacity="0.5" />
                  <circle class="eco-endpoint eco-ep-2" cx="10" cy="22" r="1.5" fill="#E8862A" opacity="0.7" />
                  <circle class="eco-joint" cx="14" cy="22" r="1.5" fill="#E8862A" opacity="0.7" />
                </svg>
              </div>
            </div>
            <h4 class="eco-title">Real-World Testbed</h4>
            <p class="eco-text">
              For bridging the gap between MAPF logic and real-world robotics, see the <strong>SMART MAPF</strong> testbed.
            </p>
            <a href="https://smart-mapf.github.io/demo/" target="_blank" rel="noopener noreferrer" class="eco-link">Explore SMART MAPF ↗</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════ SECTION 8: FOOTER ══════════ -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-copy">&copy; 2026 Stasis</span>
        <div class="footer-links">
          <a href="/about">Story</a>
          <a href="https://github.com/stasis-industry/mafis" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

  </div>

  <!-- BACK TO TOP BUTTON -->
  <button id="back-to-top" class="back-to-top" aria-label="Back to top">
    ↑ SCROLL TO TOP
  </button>

  <script is:inline>
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
    // Clean up breathing intervals on navigation
    document.addEventListener("astro:before-swap", () => {
      if (window.__breathingIntervals) {
        window.__breathingIntervals.forEach(id => clearInterval(id));
        window.__breathingIntervals = [];
      }
    });

    // Execute on initial load and after SPA view transitions
    document.addEventListener("astro:page-load", () => {
      const container = document.querySelector('.snap-container');
      const header = document.getElementById('main-header');
      const backToTop = document.getElementById('back-to-top');

      if (!container || !header || !backToTop) return;

      container.addEventListener('scroll', () => {
        // Hide header and show back to top when scrolling down past 300px
        if (container.scrollTop > 300) {
          header.classList.add('header-hidden');
          backToTop.classList.add('visible');
        } else {
          header.classList.remove('header-hidden');
          backToTop.classList.remove('visible');
        }
      });

      backToTop.addEventListener('click', () => {
        // Temporarily disable scroll snapping to allow smooth scroll to top
        container.style.scrollSnapType = 'none';
        container.scrollTo({ top: 0, behavior: 'smooth' });

        // Re-enable snapping after scrolling finishes
        setTimeout(() => {
          container.style.scrollSnapType = 'y proximity';
        }, 800);
      });

      // Stats Animation logic
      const statsSection = document.getElementById('performance-stats');
      if (statsSection) {
        const statsObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Trigger animations
              statsSection.classList.add('animated');

              // Animate Numbers
              if (!window.__breathingIntervals) window.__breathingIntervals = [];

              function startBreathing(el, target) {
                if (target === 450) return; // concurrent agents stays static
                const halfRange = target === 0 ? 2 : 1;
                const period = 3000 + Math.random() * 1000;
                const phaseOffset = Math.random() * Math.PI * 2;
                const startTime = performance.now();
                const id = setInterval(() => {
                  const elapsed = performance.now() - startTime;
                  const val = Math.max(0, Math.round(target + Math.sin(elapsed / period * Math.PI * 2 + phaseOffset) * halfRange));
                  el.innerText = val;
                }, 200);
                window.__breathingIntervals.push(id);
              }

              const counters = statsSection.querySelectorAll('.counter');
              counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-target') || '0', 10);
                const start = parseInt(counter.getAttribute('data-start') || '0', 10);
                const duration = 1500; // ms
                const startTime = performance.now();

                const updateCounter = (currentTime) => {
                  const elapsed = currentTime - startTime;
                  const progress = Math.min(elapsed / duration, 1);
                  // Ease out quad
                  const easeProgress = progress * (2 - progress);
                  const currentStr = Math.floor(start + (target - start) * easeProgress);
                  counter.innerText = currentStr;
                  if (progress < 1) {
                    requestAnimationFrame(updateCounter);
                  } else {
                    counter.innerText = target;
                    startBreathing(counter, target);
                  }
                };
                requestAnimationFrame(updateCounter);
              });

              // Animate Bars
              const fills = statsSection.querySelectorAll('.stat-fill');
              fills.forEach(fill => {
                const targetWidth = fill.getAttribute('data-width');
                fill.style.width = targetWidth; // Transitions handled by CSS
              });

              statsObserver.unobserve(statsSection);
            }
          });
        }, {
          root: container,
          threshold: 0.5
        });

        statsObserver.observe(statsSection);
      }

      // Scorecard counter animation
      const scorecard = document.getElementById('resilience-scorecard');
      if (scorecard) {
        const scorecardObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const counters = scorecard.querySelectorAll('.counter');
              counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-target') || '0', 10);
                const start = parseInt(counter.getAttribute('data-start') || '0', 10);
                const format = counter.getAttribute('data-format');
                const duration = 1500;
                const startTime = performance.now();

                const updateCounter = (currentTime) => {
                  const elapsed = currentTime - startTime;
                  const progress = Math.min(elapsed / duration, 1);
                  const easeProgress = progress * (2 - progress);
                  const current = start + (target - start) * easeProgress;

                  if (format === 'decimal') {
                    counter.innerText = '0.' + String(Math.floor(current)).padStart(2, '0');
                  } else if (format === 'slope') {
                    counter.innerText = '0.00' + Math.floor(current);
                  } else {
                    counter.innerText = Math.floor(current);
                  }

                  if (progress < 1) {
                    requestAnimationFrame(updateCounter);
                  } else {
                    if (format === 'decimal') {
                      counter.innerText = '0.' + String(target).padStart(2, '0');
                    } else if (format === 'slope') {
                      counter.innerText = '0.00' + target;
                    } else {
                      counter.innerText = target;
                    }
                  }
                };
                requestAnimationFrame(updateCounter);
              });

              scorecardObserver.unobserve(scorecard);
            }
          });
        }, {
          root: container,
          threshold: 0.5
        });

        scorecardObserver.observe(scorecard);
      }

      // Fade-in-up entrance animations
      const fadeEls = document.querySelectorAll('.fade-in-up');
      if (fadeEls.length > 0) {
        const fadeObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              fadeObserver.unobserve(entry.target);
            }
          });
        }, {
          root: container,
          threshold: 0.2
        });

        fadeEls.forEach(el => fadeObserver.observe(el));
      }
    });
  </script>

  <style>
    /* ─── Snap Container ───────────────────────────────────── */
    .snap-container {
      height: 100vh; /* Fallback */
      height: 100dvh; /* Dynamic viewport height for mobile bars */
      width: 100%;
      overflow-y: scroll;
      overflow-x: hidden;
      scroll-snap-type: y proximity;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

    /* ─── Shared ──────────────────────────────────────────── */
    .section-label {
      display: block;
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      opacity: 0.4;
      margin-bottom: 20px;
    }

    /* ─── Hero Section ─────────────────────────────────────── */
    .hero-section {
      position: relative; width: 100%;
      height: 100vh; height: 100dvh;
      overflow: hidden; background: var(--bg);
      scroll-snap-align: start;
    }
    .hero-gradient {
      position: absolute; top: 0; left: 0; bottom: 0; width: 55%; z-index: 10;
      background: linear-gradient(to right, var(--bg) 50%, transparent 100%);
      pointer-events: none;
    }
    .hero-content {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 15;
      display: flex; flex-direction: column; justify-content: center;
      padding: 0 48px; pointer-events: none;
    }
    .hero-text { max-width: 620px; pointer-events: auto; }
    .hero-title {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 6vw, 5rem);
      color: var(--text); margin-bottom: 24px;
      line-height: 1.05; letter-spacing: -1.5px;
    }
    .hero-title em { color: var(--text); opacity: 0.35; font-style: italic; }
    .hero-subtitle {
      font-family: var(--sans); font-weight: 400;
      font-size: clamp(0.95rem, 1.5vw, 1.1rem);
      color: var(--text); opacity: 0.7;
      max-width: 440px; margin-bottom: 36px; line-height: 1.8;
    }
    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

    /* Buttons */
    .btn-primary {
      display: inline-block; background: var(--dark); color: var(--text-dark);
      font-family: var(--mono); font-size: 14px; text-transform: uppercase;
      border-radius: 0; padding: 14px 28px; cursor: pointer; text-decoration: none;
      transition: opacity 0.2s; letter-spacing: 0.05em;
    }
    .btn-primary:hover { opacity: 0.85; }
    .btn-docs {
      display: inline-block; background: var(--surface);
      border: 2px solid var(--dark); color: var(--dark);
      font-family: var(--mono); font-size: 14px; text-transform: uppercase;
      border-radius: 0; padding: 12px 28px; cursor: pointer; text-decoration: none;
      transition: background 0.2s; letter-spacing: 0.05em;
    }
    .btn-docs:hover { background: #E8E4DF; }

    /* Scroll hint */
    .scroll-hint {
      position: absolute; bottom: 28px; left: 50%;
      transform: translateX(-50%); z-index: 20;
      opacity: 0.25; text-align: center;
    }
    .scroll-hint p {
      font-family: var(--mono); font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.2em; color: var(--text);
    }
    .scroll-line {
      width: 1px; height: 18px; background: var(--text);
      opacity: 0.5;
      margin: 6px auto 0; animation: scrollPulse 2s infinite;
    }

    /* ─── Section 2: The Gap ─────────────────────────────── */
    .gap-section {
      position: relative; z-index: 20;
      background: #080808; color: #F0EDE9;
      width: 100%; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 200px 32px;
      scroll-snap-align: start;
    }
    .gap-inner {
      max-width: 700px;
      text-align: left;
    }
    .gap-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.5rem);
      color: #F0EDE9;
      letter-spacing: -1px;
      line-height: 1.1;
      margin-bottom: 28px;
    }
    .gap-title em { color: #F0EDE9; opacity: 0.35; font-style: italic; }
    .gap-text {
      font-family: var(--sans); font-weight: 300;
      font-size: clamp(0.95rem, 1.3vw, 1.05rem);
      color: #F0EDE9; opacity: 0.6;
      line-height: 1.8;
      margin-bottom: 36px;
    }
    .gap-quote {
      font-family: var(--serif);
      font-style: italic;
      font-size: clamp(1.1rem, 1.8vw, 1.4rem);
      color: #F0EDE9;
      opacity: 0.85;
      border-left: 2px solid var(--red);
      padding-left: 24px;
      margin: 0;
      line-height: 1.5;
    }

    /* ─── Section 3: The Thesis ──────────────────────────── */
    .thesis-section {
      position: relative; z-index: 20;
      background: #080808; color: #F0EDE9;
      width: 100%;
      padding: 80px 0;
      scroll-snap-align: center;
    }
    .thesis-text {
      margin-bottom: 48px;
    }
    .thesis-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.5rem);
      color: #F0EDE9;
      letter-spacing: -1px;
      line-height: 1.1;
      margin-bottom: 20px;
    }
    .thesis-title em { color: #F0EDE9; opacity: 0.35; font-style: italic; }
    .thesis-desc {
      font-family: var(--sans); font-weight: 300;
      font-size: clamp(0.95rem, 1.3vw, 1.05rem);
      color: #F0EDE9; opacity: 0.6;
      max-width: 600px;
      line-height: 1.8;
    }
    .thesis-scenes {
      max-width: 1100px;
      margin: 0 auto;
      min-height: 400px;
    }
    .thesis-caption {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-align: center;
      opacity: 0.35;
      margin-top: 32px;
      color: #F0EDE9;
    }

    /* ─── Section 4: The Observatory ─────────────────────── */
    .observatory-section {
      position: relative; z-index: 20;
      background: var(--bg);
      width: 100%;
      padding: 80px 0;
      scroll-snap-align: center;
    }
    .observatory-text {
      margin-bottom: 48px;
    }
    .observatory-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.5rem);
      color: var(--text);
      letter-spacing: -1px;
      line-height: 1.1;
      margin-bottom: 20px;
    }
    .observatory-title em { color: var(--text); opacity: 0.35; font-style: italic; }
    .observatory-desc {
      font-family: var(--sans); font-weight: 300;
      font-size: clamp(0.95rem, 1.3vw, 1.05rem);
      color: var(--text); opacity: 0.6;
      max-width: 600px;
      line-height: 1.8;
    }
    .observatory-timeline {
      max-width: 1100px;
      margin: 0 auto 32px;
      min-height: 250px;
    }

    /* Scorecard */
    .scorecard {
      max-width: 700px;
      margin: 0 auto;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px 32px;
    }
    .scorecard-title {
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text);
      opacity: 0.5;
      margin-bottom: 16px;
    }
    .scorecard-metric {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-top: 1px solid var(--border);
    }
    .scorecard-metric:last-child {
      border-bottom: 1px solid var(--border);
    }
    .scorecard-metric-label {
      font-family: var(--mono);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text);
      opacity: 0.7;
    }
    .scorecard-metric-value {
      font-family: var(--mono);
      font-size: 14px;
      letter-spacing: 0.05em;
    }
    .sc-green { color: var(--green); }
    .sc-blue { color: #3DB8E8; }
    .sc-orange { color: #E8862A; }
    .sc-muted { color: var(--text); opacity: 0.5; }
    :global(html.dark) .sc-muted { color: #F0EDE9; opacity: 0.5; }

    /* ─── Section 5: Cascade ─────────────────────────────── */
    .cascade-section {
      position: relative; z-index: 20;
      background: var(--bg);
      width: 100%;
      padding: 80px 0;
      scroll-snap-align: center;
      overflow: hidden;
    }
    .cascade-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .cascade-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      color: var(--text);
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-bottom: 20px;
    }
    .cascade-title em { color: var(--text); opacity: 0.35; font-style: italic; }
    .cascade-desc {
      font-family: var(--sans); font-weight: 300;
      font-size: clamp(0.95rem, 1.3vw, 1.05rem);
      color: var(--text); opacity: 0.6;
      line-height: 1.8;
    }
    .cascade-scene-wrapper {
      width: 100%;
      overflow: hidden;
    }
    .cascade-scene {
      width: 100%;
      min-height: 350px;
    }
    /* ─── Section 6: Dark Section (Engine) ────────────────── */
    .dark-section {
      position: relative; z-index: 20; background: #080808;
      width: 100%; min-height: 100vh; color: #F0EDE9;
      display: flex; align-items: center; scroll-snap-align: start;
    }
    .section-inner {
      max-width: 1100px; margin: 0 auto; padding: 64px 32px; width: 100%;
    }
    .dark-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 4.5vw, 4rem);
      color: #F0EDE9; letter-spacing: -1px;
      line-height: 1.1; margin-bottom: 48px;
    }
    .dark-title em { color: #F0EDE9; opacity: 0.35; }

    .pillar-group:hover .pillar-row { opacity: 0.3; }
    .pillar-group .pillar-row:hover { opacity: 1; transform: translateX(8px); }

    .pillar-row {
      display: flex; align-items: flex-start; gap: 32px;
      padding: 32px 0;
      border-top: 1px solid rgba(240,237,233, 0.1);
      flex-wrap: wrap;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .pillar-group .pillar-row:last-child {
      border-bottom: 1px solid rgba(240,237,233, 0.1);
    }

    .pillar-icon-box {
      position: relative; flex-shrink: 0;
    }
    .pillar-mod {
      position: absolute; top: -14px; left: 0;
      font-family: var(--mono); font-size: 8px; color: #F0EDE9; opacity: 0.3;
      letter-spacing: 0.1em;
    }
    .pillar-icon {
      height: 64px; width: 64px; border-radius: 16px;
      background: #FFFFFF; padding: 4px;
      object-fit: cover;
    }
    :global(html.dark) .pillar-icon {
      background: rgba(255,255,255,0.05);
    }
    .pillar-content { flex: 1; min-width: 240px; padding-top: 4px; }
    .pillar-title {
      font-family: var(--mono); font-size: 13px;
      text-transform: uppercase; letter-spacing: 0.12em;
      margin-bottom: 8px; font-weight: 500;
      display: flex; align-items: center; gap: 12px;
    }
    .pillar-line {
      display: inline-block; width: 24px; height: 1px;
      background: currentColor; opacity: 0.5;
    }
    .pillar-text {
      font-family: var(--sans); font-weight: 300; font-size: 0.95rem;
      color: #F0EDE9; opacity: 0.55; max-width: 480px; line-height: 1.7;
    }

    .bevy-link {
      color: inherit;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      transition: opacity 0.2s;
    }
    .bevy-link:hover { opacity: 0.7; }

    .stats-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
      margin-top: 64px; max-width: 720px; margin-left: auto; margin-right: auto;
    }
    .stat { font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; }
    .stat-value {
      display: block; font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 2.5rem);
      margin-bottom: 6px; font-weight: 400; letter-spacing: normal;
      color: #F0EDE9;
      line-height: 1.1;
    }
    .stat-label { color: #F0EDE9; opacity: 0.45; display: inline-block; margin-bottom: 12px; font-size: 11px; }
    .stat-bar { margin: 0 auto; }
    .stat-red { color: var(--red); text-shadow: 0 0 16px rgba(153, 27, 27, 0.4); }
    .stat-green { color: var(--green); text-shadow: 0 0 16px rgba(4, 120, 87, 0.4); }
    .stat-bar {
      width: 100%; max-width: 140px; height: 2px; background: rgba(240,237,233, 0.1);
      border-radius: 1px; overflow: hidden;
    }
    .stat-fill {
      height: 100%; border-radius: 1px;
      transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Bevy Community Credit */
    .bevy-credit {
      font-family: var(--sans);
      font-weight: 300;
      font-size: 0.95rem;
      color: #F0EDE9;
      opacity: 0.65;
      text-align: center;
      max-width: 520px;
      margin: 64px auto 0;
      line-height: 1.7;
    }
    .bevy-credit-link {
      color: #F0EDE9;
      font-weight: 400;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      transition: opacity 0.2s;
    }
    .bevy-credit-link:hover { opacity: 0.7; }

    /* ─── Section 7: Community / Ecosystem ────────────────── */
    .community-section {
      width: 100%; background: #080808; color: #F0EDE9; padding: 80px 0;
      position: relative; z-index: 20; scroll-snap-align: start;
    }
    .community-title {
      font-family: var(--serif); font-size: clamp(1.8rem, 3vw, 2.5rem);
      margin-bottom: 24px; letter-spacing: -0.5px;
    }
    .community-title em { font-style: italic; color: #F0EDE9; opacity: 0.5; }
    .community-intro {
      font-family: var(--sans); font-weight: 300; font-size: 1rem;
      color: #F0EDE9; opacity: 0.6; max-width: 640px; margin-bottom: 48px;
      line-height: 1.6;
    }

    .ecosystem-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
    }
    .eco-card {
      position: relative; overflow: hidden;
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; padding: 32px;
      transition: border-color 0.3s, background 0.3s, transform 0.3s ease;
    }
    .eco-card:hover { border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05); transform: translateY(-4px); }
    .eco-bg-number {
      position: absolute; right: -10px; bottom: -20px;
      font-family: var(--serif); font-size: 8rem; font-style: italic;
      color: #F0EDE9; opacity: 0.03; line-height: 1;
      pointer-events: none; user-select: none;
    }
    .eco-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      margin-bottom: 20px;
    }
    .eco-tag {
      font-family: var(--mono); font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: #F0EDE9; opacity: 0.4;
    }
    /* Ecosystem animated icons */
    .eco-icon-anim { display: flex; align-items: center; }
    .eco-anim-svg { overflow: visible; }

    /* Bar chart animation for card 1 */
    .eco-bar { transform-origin: bottom center; animation: eco-bar-grow 2.5s ease-in-out infinite; }
    .eco-bar-1 { animation-delay: 0s; }
    .eco-bar-2 { animation-delay: 0.2s; }
    .eco-bar-3 { animation-delay: 0.4s; }
    .eco-bar-4 { animation-delay: 0.6s; }
    @keyframes eco-bar-grow {
      0%, 100% { transform: scaleY(1); }
      50% { transform: scaleY(0.5); }
    }

    /* Grid cell pulse for card 2 */
    .eco-cell { animation: eco-cell-pulse 3s ease-in-out infinite; }
    .eco-cell-1 { animation-delay: 0s; }
    .eco-cell-2 { animation-delay: 0.3s; }
    .eco-cell-3 { animation-delay: 0.6s; }
    .eco-cell-4 { animation-delay: 0.9s; }
    .eco-cell-5 { animation-delay: 0.15s; }
    .eco-cell-6 { animation-delay: 0.45s; }
    .eco-cell-7 { animation-delay: 0.75s; }
    .eco-cell-8 { animation-delay: 1.05s; }
    .eco-cell-9 { animation-delay: 0.5s; }
    @keyframes eco-cell-pulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 0.8; }
    }

    /* Robot arm sway for card 3 */
    .eco-arm-2, .eco-arm-3 { transform-origin: 14px 10px; animation: eco-arm-sway 3s ease-in-out infinite; }
    .eco-arm-3 { animation-delay: 0.1s; animation-direction: reverse; }
    .eco-ep-1, .eco-ep-2 { animation: eco-ep-pulse 2s ease-in-out infinite; }
    .eco-ep-2 { animation-delay: 1s; }
    @keyframes eco-arm-sway {
      0%, 100% { transform: rotate(0deg); }
      50% { transform: rotate(5deg); }
    }
    @keyframes eco-ep-pulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }
    .eco-title {
      font-family: var(--mono); font-size: 11px; text-transform: uppercase;
      letter-spacing: 0.12em; color: #F0EDE9; opacity: 0.9; margin-bottom: 12px;
      position: relative; z-index: 2;
    }
    .eco-text {
      font-family: var(--sans); font-weight: 300; font-size: 0.9rem;
      color: #F0EDE9; opacity: 0.5; margin-bottom: 24px; line-height: 1.6;
      position: relative; z-index: 2;
    }
    .eco-text strong {
      font-weight: 500; color: #F0EDE9; opacity: 0.8;
    }
    .eco-link {
      display: inline-block; font-family: var(--mono); font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.1em; color: #F0EDE9; opacity: 0.9;
      text-decoration: none; padding-bottom: 4px;
      border-bottom: 1px solid rgba(255,255,255,0.15); transition: opacity 0.2s;
    }
    .eco-link:hover { opacity: 0.6; }

    /* ─── Footer ───────────────────────────────────────────── */
    .site-footer {
      width: 100%; background: var(--bg); padding: 40px 32px;
      border-top: 1px solid var(--border);
      position: relative; z-index: 20; scroll-snap-align: end;
    }
    .footer-inner {
      max-width: 1100px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer-copy, .footer-links a {
      font-family: var(--mono); font-size: 11px;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--text-sec); text-decoration: none;
    }
    .footer-links { display: flex; gap: 24px; }

    /* ─── Back to Top ──────────────────────────────────────── */
    .back-to-top {
      position: fixed;
      bottom: 40px;
      right: 40px;
      z-index: 90;
      background: transparent;
      border: none;
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text-sec);
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transform: translateY(10px);
      transition: all 0.3s ease;
    }
    .back-to-top.visible {
      opacity: 0.5;
      pointer-events: auto;
      transform: translateY(0);
    }
    .back-to-top:hover {
      opacity: 1;
      color: var(--text);
    }

    /* ─── Responsive ───────────────────────────────────────── */
    @media (max-width: 900px) {
      .hero-gradient { width: 100%; background: linear-gradient(to right, var(--bg) 60%, transparent 100%); }
      .hero-content { padding: 0 24px; }
      .ecosystem-grid { grid-template-columns: 1fr; gap: 24px; }
      .stats-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; }
      .dark-section, .community-section { min-height: 100dvh; padding: 64px 0; }
      .section-inner { padding: 48px 24px; }

      .pillar-row { flex-direction: row; align-items: flex-start; gap: 16px; padding: 20px 0; flex-wrap: nowrap; }
      .pillar-icon { height: 48px; width: 48px; padding: 4px; border-radius: 12px; flex-shrink: 0; }
      .pillar-content { flex: 1; min-width: 0; }

      .back-to-top { bottom: 24px; right: 24px; }

      /* Cascade: stack vertically */
      .cascade-layout { grid-template-columns: 1fr; gap: 32px; }

      /* Gap section */
      .gap-section { padding: 80px 24px; min-height: 100dvh; }
      .gap-text { margin-bottom: 24px; }

      /* Thesis section */
      .thesis-section { padding: 64px 0; }
      .thesis-text { margin-bottom: 32px; }

      /* Observatory section */
      .observatory-section { padding: 64px 0; }
      .observatory-text { margin-bottom: 32px; }
      .observatory-timeline { margin-bottom: 32px; min-height: 200px; }

      /* Cascade section */
      .cascade-section { padding: 64px 0; }

      /* Engine */
      .dark-title { margin-bottom: 32px; }
      .bevy-credit { margin-top: 32px; }
    }

    @media (max-width: 600px) {
      .hero-canvas-wrapper { display: none; }
      .hero-content { padding: 0 20px; height: 100vh; height: 100dvh; display: flex; flex-direction: column; justify-content: center; }
      .hero-title { font-size: 3.2rem; margin-bottom: 20px; line-height: 1.05; }
      .hero-subtitle { font-size: 0.95rem; line-height: 1.7; margin-bottom: 32px; }
      .hero-cta { flex-direction: column; gap: 12px; width: 100%; }
      .hero-cta .btn-primary, .hero-cta .btn-docs { text-align: center; width: 100%; padding: 16px 28px; }

      /* Engine section: let it flow naturally, no forced viewport */
      .dark-section { min-height: auto; padding: 48px 0; background-color: #080808; }

      .section-inner { padding: 32px 20px; width: 100%; }
      .dark-title { font-size: 2rem; margin-bottom: 20px; }

      .pillar-row { padding: 14px 0; flex-wrap: nowrap; gap: 12px; align-items: flex-start; }
      .pillar-icon-box { margin-top: 2px; }
      .pillar-icon { height: 40px; width: 40px; border-radius: 10px; }
      .pillar-mod { display: none; }
      .pillar-title { font-size: 10px; margin-bottom: 4px; }
      .pillar-line { width: 12px; }
      .pillar-text { font-size: 0.8rem; line-height: 1.4; }

      .pillar-group:hover .pillar-row { opacity: 1; transform: none; }
      .pillar-group .pillar-row:hover { transform: none; }

      /* Stats: keep 3 columns, shrink fonts */
      .stats-grid { margin-top: 24px; gap: 8px; grid-template-columns: repeat(3, 1fr); }
      .stat-value { font-size: 1.2rem; }
      .stat-label { font-size: 8px; margin-bottom: 4px; }
      .stat-bar { max-width: 60px; }

      .community-section { padding: 48px 0; border-top: none; }
      .community-title { font-size: 1.8rem; margin-bottom: 16px; }
      .community-intro { font-size: 0.85rem; margin-bottom: 24px; }

      .footer-inner { flex-direction: column; gap: 16px; text-align: center; }

      /* Gap section mobile */
      .gap-section { padding: 80px 20px; }
      .gap-title { font-size: 1.8rem; margin-bottom: 24px; }
      .gap-text { font-size: 0.9rem; margin-bottom: 28px; line-height: 1.7; }
      .gap-quote { font-size: 1.05rem; line-height: 1.6; }

      /* Thesis mobile */
      .thesis-section { padding: 60px 0; }
      .thesis-title { font-size: 1.8rem; margin-bottom: 16px; }
      .thesis-text { margin-bottom: 28px; }
      .thesis-desc { font-size: 0.9rem; line-height: 1.7; }
      .thesis-scenes { min-height: auto; }
      .thesis-caption { margin-top: 20px; font-size: 9px; letter-spacing: 0.08em; }

      /* Observatory mobile */
      .observatory-section { padding: 60px 0; }
      .observatory-title { font-size: 1.8rem; margin-bottom: 16px; }
      .observatory-desc { font-size: 0.9rem; line-height: 1.7; }
      .observatory-timeline { min-height: 180px; margin-bottom: 28px; }
      .scorecard { padding: 24px 20px; }
      .scorecard-title { margin-bottom: 16px; }
      .scorecard-metric { padding: 12px 0; }
      .scorecard-metric-label { font-size: 11px; letter-spacing: 0.1em; }
      .scorecard-metric-value { font-size: 14px; }

      /* Cascade mobile */
